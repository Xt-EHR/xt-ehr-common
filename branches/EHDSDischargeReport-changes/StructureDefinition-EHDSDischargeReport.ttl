       fhir:id [ fhir:v "EHDSDischargeReport.body.courseOfEncounter" ] ;
       fhir:path [ fhir:v "EHDSDischargeReport.body.courseOfEncounter" ] ;
       fhir:short [ fhir:v "Course of inpatient or outpatient encounter." ] ;
       fhir:definition [ fhir:v "Course of inpatient or outpatient encounter." ] ;
       fhir:requirements [ fhir:v "eHN Guideline HDR (v1.1): A.2.6" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
